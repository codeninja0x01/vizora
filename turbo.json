{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "DATABASE_URL",
        "DIRECT_DATABASE_URL",
        "BETTER_AUTH_SECRET",
        "BETTER_AUTH_URL",
        "NEXT_PUBLIC_APP_URL",
        "NEXT_PUBLIC_STRIPE_PRO_PRICE_ID",
        "DEEPGRAM_URL",
        "DEEPGRAM_API_KEY",
        "DEEPGRAM_MODEL",
        "ELEVENLABS_API_KEY",
        "ELEVENLABS_URL",
        "ELEVENLABS_MODEL",
        "R2_PUBLIC_DOMAIN",
        "R2_BUCKET_NAME",
        "R2_ACCESS_KEY_ID",
        "R2_SECRET_ACCESS_KEY",
        "R2_ACCOUNT_ID",
        "R2_SERVE_MODE",
        "PEXELS_URL",
        "PEXELS_API_KEY",
        "GEMINI_API_KEY",
        "GOOGLE_GENAI_API_KEY",
        "UPSTASH_REDIS_REST_URL",
        "UPSTASH_REDIS_REST_TOKEN",
        "STRIPE_WEBHOOK_SECRET",
        "STRIPE_SECRET_KEY",
        "STRIPE_PRO_PRICE_ID",
        "TRUSTED_ORIGINS"
      ]
    },
    "lint": {
      "dependsOn": []
    },
    "check-types": {
      "dependsOn": []
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["coverage/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
